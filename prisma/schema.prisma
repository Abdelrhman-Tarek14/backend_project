generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// Enums
// =======================
enum Role {
  SUPER_USER
  ADMIN
  SUPERVISOR
  CMD
  LEADER
  SUPPORT
  AGENT
  NEW_USER
}

enum AssignmentStatus {
  OPEN
  CLOSED
}

// =======================
// 1. Users Table
// =======================
model User {
  id                 String       @id @default(uuid())
  name               String
  email              String       @unique
  passwordHash       String?      
  googleId           String?      @unique 
  role               Role         @default(NEW_USER)
  isActive           Boolean      @default(true)
  

  hashedRefreshToken String?      @map("hashed_refresh_token")
  isOnline           Boolean      @default(false)
  lastActive         DateTime?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt


  // -- Team Hierarchy (Self-Referencing) --
  leaderId           String?
  leader             User?        @relation("TeamHierarchy", fields: [leaderId], references: [id])
  team               User[]       @relation("TeamHierarchy")

  assignments        Assignment[] @relation("UserAssignments")
  assignedOthers     Assignment[] @relation("AssignedBy")
  userLogs           UserLog[]
  caseLogs           CaseLog[]

  @@index([role, isActive])
  @@index([leaderId])
}

// =======================
// 2. Cases Table (Static Identity)
// =======================
model Case {
  id                String       @id @default(uuid())
  caseNumber        String       @unique
  
  // -- Static Fields from Salesforce --
  accountName       String?
  country           String?      
  
  receiveCount      Int          @default(1)
  lastClosedAt      DateTime?    
  
  createdAt         DateTime     @default(now())



  assignments       Assignment[]

  @@index([createdAt])
}

// =======================
// 3. Assignments Table (Dynamic Session)
// =======================
model Assignment {
  id           String           @id @default(uuid())
  caseId       String
  userId       String?
  ownerEmail   String?
  
  // -- Dynamic Fields --
  status       AssignmentStatus @default(OPEN)
  caseType     String?          // from Salesforce (can change per session)
  formType     String?          // from GAS (agent input)
  
  // -- GAS Validation Fields --
  items        Int?
  choices      Int?
  description  Int?
  images       Int?
  tmpAreas     Int?
  isValid      Boolean?
  isOnTime     Boolean?
  formSubmitTime DateTime?
  qualityScore Boolean?
  finalCheckScore Boolean?
  
  startTime    DateTime?        // when the work started
  etaMinutes   Int?             // ETA provided by GAS
  etaSetAt     DateTime?        // when ETA was recorded
  
  isActive     Boolean          @default(true) // Legacy support: preferably use status
  
  closedAt DateTime?
  assignedAt DateTime @default(now())
  
  assignedById String?


  case         Case             @relation(fields: [caseId], references: [id])
  user         User?            @relation("UserAssignments", fields: [userId], references: [id])
  assignedBy   User?            @relation("AssignedBy", fields: [assignedById], references: [id])
  caseLogs     CaseLog[]

  @@index([userId, assignedAt])
  @@index([caseId])
  @@index([status])
}

// =======================
// 4. Case Logs Table
// =======================
model CaseLog {
  id           String     @id @default(uuid())
  assignmentId String
  action       String     
  performedBy  String?    
  userId       String?
  changes      Json?      
  createdAt    DateTime   @default(now())


  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User?      @relation(fields: [userId], references: [id])

  @@index([assignmentId, createdAt])
  @@index([userId, createdAt])
}

// =======================
// 5. User Logs Table
// =======================
model UserLog {
  id           String     @id @default(uuid())
  userId       String
  state        String     // "LOGGED_IN", "LOGGED_OUT", "ONLINE", "OFFLINE"
  createdAt    DateTime   @default(now())

  // Relations
  user         User       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}