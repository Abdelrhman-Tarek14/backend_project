{
  "name": "salesforce-api-worker",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon --ignore data/ --watch src --ext ts,json --exec \"ts-node src/main.ts\"",
    "build": "tsc",
    "start": "node dist/main.js",
    "clear": "node -e \"require('fs').rmSync('data/state.json', {force:true})\"",
    "lint": "eslint 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
